# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Don't upload the py dir until the API key has been made a secret
/priv/static/assets/py

# esbuild output — regenerated by `mix assets.deploy` on every Gigalixir
# deploy via hook_post_compile. Tracking them just causes dev-mode rebuild
# noise + risks leaking inline source maps if a dev-mode build is committed.
/priv/static/assets/app.js
/priv/static/assets/app.css

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
mono_phoenix_v01-*.tar

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Visual Studio Code Elixir LS build artifacts
.elixir_ls/

# Playwright MCP browser-testing artifacts (console logs + page snapshots)
/.playwright-mcp/

# Secrets, creds, n such
/config/prod.secret.txt
/config/dev.exs
/config/test.exs
/config/.env
/config/.env.bak.*

CLAUDE.md
/.claude/

misc backup habits
*.bak
*.2023*
\#*#
\#.*#
screenshot-*.png
